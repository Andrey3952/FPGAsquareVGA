`timescale 1ns / 1ps
module vgaGame(
    input wire clk, rts,
    input wire [9:0] ball_x, ball_y,
    input wire [9:0] paddle1_y, paddle2_y
    output wire h_sync, v_sync,
    output wire red, green, blue
);

reg pixel_en;

parameter H_DISPLAY = 640;
parameter H_MAX = 800;

parameter V_DISPLAY = 480;
parameter V_MAX = 525;

parameter H_SIZE = 50; // Довжина квадрата 
parameter V_SIZE = 50; // Висота квадрата 

parameter SPEED = 1;

parameter BALL_SIZE = 10;
parameter PADDLE_W = 10; // Ширина ракетки
parameter PADDLE_H = 60; // Висота ракетки


reg [9:0] h_count = 0;
reg [9:0] v_count = 0;

always @(posedge clk or negedge rts)begin
    if(!rts)begin
        pixel_en <= 0;
    end else begin
        pixel_en <= ~pixel_en;
    end
end 

always @(posedge clk or negedge  rts)begin
    if(!rts)begin
        h_count <= 0;
        v_count <= 0;
    end else begin
        if(pixel_en)begin
            if(h_count == (H_MAX - 1)) begin 
                h_count <= 0;
                if(v_count == (V_MAX - 1))begin
                    v_count <=0;
                end else begin
                    v_count <= v_count + 1;
                end
            end else begin 
                h_count <= h_count + 1;
            end
        end
    end
end

assign h_sync = (h_count >= 656 && h_count < 752) ? 1'b0 : 1'b1;
assign v_sync = (v_count >= 490 && v_count < 492) ? 1'b0 : 1'b1;
wire video_on;
assign video_on = (h_count < H_DISPLAY && v_count < V_DISPLAY);


wire is_ball = (h_count >= ball_x && h_count < ball_x + BALL_SIZE && v_count >= ball_y && v_count < ball_y + BALL_SIZE);
wire is_pad1 = (h_count >= 20 && h_count < 20 + PADDLE_W && v_count >= paddle1_y && v_count < paddle1_y + PADDLE_H);
wire is_pad2 = (h_count >= 610 && h_count < 610 + PADDLE_W && v_count >= paddle2_y && v_count < paddle2_y + PADDLE_H);

// assign green = (video_on) ? 1'b1 : 1'b0;
// assign blue = (video_on) ? 1'b1 : 1'b0;


// v_count висота 480 
// h_count довжина 640

assign red   = (video_on && (is_ball || is_pad1 || is_pad2)) ? 1'b1 : 1'b0;
assign green = (video_on && (is_ball || is_pad1 || is_pad2)) ? 1'b1 : 1'b0;
assign blue  = (video_on && (is_ball || is_pad1 || is_pad2)) ? 1'b1 : 1'b0;

endmodule

